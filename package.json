{
  "name": "splunk-app-generator-starter",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:splunk": "tsc -b && vite build --config vite.splunk.config.ts",
    "sanity:instructions": "node scripts/sanity-check-instructions.mjs",
    "sanity:examples": "node scripts/sanity-check-examples.mjs",
    "sanity:appid": "node scripts/sanity-check-appid.mjs",
    "test:backend": "node scripts/run-python-tests.mjs",
    "splunk:sync": "node scripts/splunk-sync.mjs",
    "example:pick": "node scripts/pick-example.mjs",
    "release:check": "node scripts/run-release-gates.mjs",
    "package:splunk": "npm run sanity:instructions && npm run sanity:examples && npm run sanity:appid && npm run build:splunk && npm run splunk:sync && node scripts/splunk-package.mjs",
    "validate": "npm run lint && npm run sanity:instructions && npm run sanity:examples && npm run sanity:appid && npm run test:backend && npm run build:splunk",
    "template:rename": "node scripts/template-rename.mjs",
    "variant:dashboard": "node scripts/apply-variant.mjs --variant dashboard-first",
    "variant:minimal": "node scripts/apply-variant.mjs --variant minimal-ui",
    "variant:rest-crud": "node scripts/apply-variant.mjs --variant rest-crud",
    "variant:rich": "node scripts/apply-variant.mjs --variant rich-ui",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@splunk/react-ui": "^5.9.0",
    "@splunk/themes": "^1.6.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "styled-components": "^5.3.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^18.3.26",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4"
  }
}
